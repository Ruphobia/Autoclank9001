data/
resources/
kicad/

# Runtime state (per-session, per-cwd, per-user)
005_context/
.tool_runs/
.cache/
.toolai/
.ac9/

# Local secrets (mouser API key, any other credentials)
settings/
*credentials.json
*api_key*
*.pem
.env
.env.*

# Runtime logs (per-session, not source)
scratchpad/*.log
nohup.out
*.log

