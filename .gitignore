# Build artifacts
build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json
_deps/
/tool
/tool_test
/ac9
/ac9_test
*.o
*.a
*.so
*.so.*
*.d

# llama.cpp / ggml shared libs (built from _deps or fetched)
bin/
libsqlite3_amalgamation.a

# Generated headers (recreated at build time from data)
interface_gen/

# Data lives in /data/ as sha256-named .bin chunks (models, dictionary,
# wikipedia, safety, thesaurus). Chunks are big and fetched via manifest,
# so they're never committed. But README.md and manifest.json ARE
# committed so the repo carries the format doc and the role -> sha map.
# Leading slash keeps this from matching modules/data/ (the C++ source
# for the chunk/manifest module).
/data/*.bin
/data/staging/
/resources/

# Runtime state (per-session, per-cwd, per-user).
# /005_context/ is the top-level runtime session dir. Leading slash
# prevents matching modules/005_context/ (which is the module SOURCE).
/005_context/
modules/005_context/sessions/
.tool_runs/
.cache/
.toolai/
.ac9/

# Local secrets (mouser API key, any other credentials)
settings/
*credentials.json
*api_key*
*.pem
.env
.env.*

# Runtime logs (per-session, not source)
scratchpad/*.log
nohup.out
*.log

# Editor / OS junk
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~
